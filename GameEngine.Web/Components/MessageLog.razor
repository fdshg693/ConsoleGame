@* 累積メッセージログ。サーバは差分のみ返すため、累積は SessionStore が保持し、ここは表示に徹する。 *@

<div class="panel message-log">
    <div class="panel-title">ログ</div>
    @if (Messages is null || Messages.Count == 0)
    {
        <p class="text-muted"><em>(メッセージはまだありません)</em></p>
    }
    else
    {
        <ul class="log-list">
            @foreach (var msg in Messages)
            {
                <li class="log-line @CssFor(msg.Type)">@msg.Text</li>
            }
        </ul>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<GameMessage>? Messages { get; set; }

    private static string CssFor(MessageType type) => type switch
    {
        MessageType.Success => "log-success",
        MessageType.Warning => "log-warning",
        MessageType.Error => "log-error",
        MessageType.Combat => "log-combat",
        MessageType.Experience => "log-exp",
        MessageType.Gold => "log-gold",
        _ => "log-info"
    };
}
