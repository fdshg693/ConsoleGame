@page "/play"
@implements IDisposable
@inject GameApiClient Api
@inject SessionStore Store
@inject NavigationManager Nav

<PageTitle>プレイ - Console RPG</PageTitle>

@if (_recovering)
{
    <div class="recovering">
        <span class="spinner"></span>
        <span>中断した冒険を復帰しています...</span>
    </div>
}
else if (_sessionExpired)
{
    <div class="alert alert-warning" role="alert">セッションが失効しました。新しい冒険を始めてください。</div>
    <button class="btn btn-primary" @onclick="GoToMenu">メニューへ</button>
}
else if (Store.Current is null)
{
    <p><em>セッションがありません。メニューへ戻ります...</em></p>
}
else
{
    var state = Store.Current;

    <div class="play-grid">
        <aside class="play-side">
            <PlayerPanel Player="state.Player" />
            <MessageLog Messages="Store.Log" />

            @if (Store.SaveAvailable == true && state.IsRunning)
            {
                <div class="panel save-box">
                    <div class="panel-title">セーブ</div>
                    <label class="save-slot-label">
                        スロット
                        <input class="form-control" @bind="_saveSlot" placeholder="auto_save" disabled="@_busy" />
                    </label>
                    <button class="btn btn-info btn-sm" disabled="@_busy" @onclick="SaveGameAsync">この内容をセーブ</button>
                    @if (_saveMessage is not null)
                    {
                        <p class="save-status">@_saveMessage</p>
                    }
                </div>
            }
        </aside>

        <section class="play-main">
            @if (_error is not null)
            {
                <div class="alert alert-danger" role="alert">@_error</div>
            }

            @if (state.ExpectedInput == ExpectedInput.Attack)
            {
                <h2>戦闘</h2>
                <EnemyPanel Enemy="state.CurrentEnemy" />
                @if (state.CurrentBattle is not null)
                {
                    <p class="turn">ターン @state.CurrentBattle.TurnNumber</p>
                    <div class="action-row">
                        @foreach (var strategy in state.CurrentBattle.AvailableStrategies)
                        {
                            var s = strategy;
                            <button class="btn btn-danger" disabled="@_busy" @onclick="() => AttackAsync(s)">@s で攻撃</button>
                        }
                    </div>
                }
            }
            else if (state.ExpectedInput == ExpectedInput.Shop && state.CurrentShop is not null)
            {
                <h2>ショップ</h2>
                <div class="shop-section">
                    <h3>ポーション（@state.CurrentShop.PotionPrice Gold）</h3>
                    <div class="action-row">
                        <label>数量 <input type="number" min="1" class="qty-input" @bind="_potionQty" /></label>
                        <button class="btn btn-success" disabled="@_busy" @onclick="BuyPotionAsync">ポーション購入</button>
                    </div>
                </div>

                <div class="shop-section">
                    <h3>武器</h3>
                    @if (state.CurrentShop.AvailableWeapons.Count == 0)
                    {
                        <p class="text-muted"><em>(購入可能な武器なし)</em></p>
                    }
                    else
                    {
                        <ul class="weapon-list">
                            @foreach (var weapon in state.CurrentShop.AvailableWeapons)
                            {
                                var w = weapon;
                                <li>
                                    <span>@w.Name（AP @w.AttackPower / DP @w.DefensePower / @w.Price Gold）</span>
                                    <button class="btn btn-outline-success btn-sm" disabled="@_busy" @onclick="() => BuyWeaponAsync(w.Name)">購入</button>
                                </li>
                            }
                        </ul>
                    }
                </div>

                <div class="action-row">
                    <button class="btn btn-secondary" disabled="@_busy" @onclick="ExitShopAsync">ショップを出る</button>
                </div>
            }
            else if (state.ExpectedInput == ExpectedInput.Rest)
            {
                <h2>休憩</h2>
                <p>ポーションを使って回復するか、そのまま進めます。</p>
                <div class="action-row">
                    <button class="btn btn-success" disabled="@(_busy || state.Player.Potions <= 0)" @onclick="UsePotionAsync">
                        ポーションを使う（所持 @state.Player.Potions）
                    </button>
                    <button class="btn btn-secondary" disabled="@_busy" @onclick="SkipRestAsync">何もせず進む</button>
                </div>
            }
            else if (state.ExpectedInput == ExpectedInput.GameAction)
            {
                <h2>次へ</h2>
                <p>このエンカウントを終えました。続けますか？</p>
                <div class="action-row">
                    <button class="btn btn-primary" disabled="@_busy" @onclick="ContinueGameAsync">続ける</button>
                    @if (Store.SaveAvailable == true)
                    {
                        <button class="btn btn-info" disabled="@_busy" @onclick="SaveAndContinueAsync">セーブして続ける</button>
                        <button class="btn btn-outline-info" disabled="@_busy" @onclick="SaveAndQuitAsync">セーブして終了</button>
                    }
                    <button class="btn btn-outline-secondary" disabled="@_busy" @onclick="QuitGameAsync">終了する</button>
                </div>
            }
            else
            {
                @* ExpectedInput.None = 終了 / ゲームオーバー（Quit も IsGameOver=true で返る） *@
                <div class="ending-panel @(state.IsGameOver ? "is-gameover" : "is-clear")">
                    <h2>@(state.IsGameOver ? "ゲームオーバー" : "ゲーム終了")</h2>
                    <p class="ending-lead">@(state.IsGameOver ? "力尽きてしまった..." : "冒険はここまで。お疲れさまでした。")</p>
                    <ul class="ending-summary">
                        <li><span>到達レベル</span><span>Lv @state.Player.Level</span></li>
                        <li><span>経験値</span><span>@state.Player.Experience EXP</span></li>
                        <li><span>所持ゴールド</span><span>@state.Player.Gold Gold</span></li>
                    </ul>
                    <div class="action-row">
                        <button class="btn btn-primary" disabled="@_busy" @onclick="ReplayAsync">同じ名前でもう一度</button>
                        <button class="btn btn-outline-secondary" disabled="@_busy" @onclick="BackToMenuAsync">メニューに戻る</button>
                    </div>
                </div>
            }
        </section>
    </div>
}

@code {
    private bool _busy;
    private string? _error;
    private bool _sessionExpired;
    private bool _recovering;
    private int _potionQty = 1;
    private string _saveSlot = string.Empty;
    private string? _saveMessage;

    protected override async Task OnInitializedAsync()
    {
        Store.OnChange += OnStoreChanged;

        // Home からの遷移なら Store.Current が入っている。直接アクセス/リロードで揮発した場合は
        // localStorage の sessionId から GET /sessions/{id} で進行を復帰する（W4 リロード復帰）。
        // 復帰元が無い / 失効していればメニューへ戻す。
        if (Store.Current is null)
        {
            _recovering = true; // 最初の描画からスピナーを出す（"セッションがありません" のちらつき防止）。
            if (!await TryRecoverSessionAsync())
            {
                Nav.NavigateTo("/");
                return;
            }
        }

        await ProbeSaveAvailabilityAsync();
    }

    /// <summary>
    /// リロード等で揮発したクライアント状態を localStorage の sessionId から復帰する。
    /// 復帰できれば true。sessionId が無い／失効（404）なら痕跡をクリアして false（呼び出し側がメニューへ）。
    /// </summary>
    private async Task<bool> TryRecoverSessionAsync()
    {
        await Store.LoadSessionIdAsync();
        if (Store.SessionId is null)
        {
            return false; // 復帰元が無い。
        }

        try
        {
            var state = await Api.GetSessionAsync(Store.SessionId);
            await Store.ApplyAsync(state);
            return true;
        }
        catch (GameApiException ex) when (ex.StatusCode == HttpStatusCode.NotFound)
        {
            await Store.ClearAsync(); // 失効 → 痕跡を消してメニューへ誘導。
            return false;
        }
        catch
        {
            // ネットワーク不調等は復帰失敗としてメニューへ（安全側）。痕跡は残し再試行余地を残す。
            return false;
        }
        finally
        {
            _recovering = false;
        }
    }

    public void Dispose() => Store.OnChange -= OnStoreChanged;

    private void OnStoreChanged() => InvokeAsync(StateHasChanged);

    private string SessionId => Store.SessionId!;

    /// <summary>セーブ可否を一度だけ判定する（読み取り専用の一覧取得で 503 なら無効と判断）。</summary>
    private async Task ProbeSaveAvailabilityAsync()
    {
        if (Store.SaveAvailable is not null)
        {
            return; // 既に判定済み（Home でのロード等）。
        }

        try
        {
            await Api.GetSavesAsync(Store.Current!.Player.Name);
            Store.SetSaveAvailable(true);
        }
        catch (GameApiException ex) when (ex.StatusCode == HttpStatusCode.ServiceUnavailable)
        {
            Store.SetSaveAvailable(false);
        }
        catch
        {
            // 判定不能（ネットワーク等）。安全側に倒してセーブ UI は出さない（未判定のまま）。
        }
    }

    // ---- 進行アクション（ExpectedInput 別。文字列リテラルは C# 側に置く） ----

    private Task AttackAsync(string strategy) => RunAsync(() => Api.BattleTurnAsync(SessionId, strategy));

    private Task BuyPotionAsync() =>
        RunAsync(() => Api.ShopActionAsync(SessionId, new ShopAction(ShopActionType.BuyPotion, quantity: Math.Max(1, _potionQty))));

    private Task BuyWeaponAsync(string name) =>
        RunAsync(() => Api.ShopActionAsync(SessionId, new ShopAction(ShopActionType.BuyWeapon, name)));

    private Task ExitShopAsync() =>
        RunAsync(() => Api.ShopActionAsync(SessionId, new ShopAction(ShopActionType.Exit)));

    private Task UsePotionAsync() => RunAsync(() => Api.RestAsync(SessionId, new UseItemAction("Potion", 1)));

    private Task SkipRestAsync() => RunAsync(() => Api.RestAsync(SessionId, null));

    private Task ContinueGameAsync() => RunAsync(() => Api.ContinueAsync(SessionId, GameActionChoice.Continue));

    private Task QuitGameAsync() => RunAsync(() => Api.ContinueAsync(SessionId, GameActionChoice.Quit));

    // セーブ付きの進行（既定スロットへ確定セーブ）。リポジトリ未設定時はサーバ側で黙ってスキップされるため、
    // ボタン自体を SaveAvailable で出し分けて誤操作を避ける。
    private Task SaveAndContinueAsync() => RunAsync(() => Api.ContinueAsync(SessionId, GameActionChoice.SaveAndContinue));

    private Task SaveAndQuitAsync() => RunAsync(() => Api.ContinueAsync(SessionId, GameActionChoice.SaveAndQuit));

    /// <summary>進行ステップの共通実行。二重送信防止＋ステップ適用＋ステータス別エラー処理。</summary>
    private async Task RunAsync(Func<Task<GameStateResponse>> step)
    {
        if (_busy)
        {
            return; // 二重送信防止（送信中は各ボタンも disabled）。
        }

        _busy = true;
        _error = null;
        _saveMessage = null;
        try
        {
            var next = await step();
            await Store.ApplyAsync(next);
        }
        catch (GameApiException ex)
        {
            await HandleApiErrorAsync(ex);
        }
        catch (Exception ex)
        {
            _error = $"通信に失敗しました: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>明示的な確定セーブ（任意スロット）。503 はセーブ UI を無効化する。</summary>
    private async Task SaveGameAsync()
    {
        if (_busy)
        {
            return;
        }

        _busy = true;
        _error = null;
        _saveMessage = null;
        try
        {
            var slot = string.IsNullOrWhiteSpace(_saveSlot) ? null : _saveSlot.Trim();
            await Api.SaveAsync(SessionId, slot);
            Store.SetSaveAvailable(true);
            _saveMessage = $"セーブしました（スロット: {slot ?? "auto_save"}）。";
        }
        catch (GameApiException ex)
        {
            await HandleApiErrorAsync(ex);
        }
        catch (Exception ex)
        {
            _error = $"通信に失敗しました: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>HTTP ステータス別のハンドリング（404→失効誘導 / 409→再取得 / 503→セーブ無効化 / その他→表示）。</summary>
    private async Task HandleApiErrorAsync(GameApiException ex)
    {
        switch (ex.StatusCode)
        {
            case HttpStatusCode.NotFound:           // セッション失効 → メニューへ誘導
                _sessionExpired = true;
                await Store.ClearAsync();
                break;

            case HttpStatusCode.Conflict:           // ExpectedInput 不一致 → 最新状態に同期
                await ResyncAsync();
                break;

            case HttpStatusCode.ServiceUnavailable: // セーブ未設定/到達不可 → セーブ UI 無効化
                Store.SetSaveAvailable(false);
                _error = "セーブ機能は利用できません（サーバにセーブ先が構成されていません）。";
                break;

            default:                                 // 400（バリデーション）など
                _error = ex.Message;
                break;
        }
    }

    /// <summary>409 時に現在状態を取り直してクライアントを整合させる。再取得で 404 なら失効扱い。</summary>
    private async Task ResyncAsync()
    {
        try
        {
            var latest = await Api.GetSessionAsync(SessionId);
            await Store.ApplyAsync(latest);
            _error = "操作が現在の状態と一致しなかったため、最新の状態に同期しました。";
        }
        catch (GameApiException ex) when (ex.StatusCode == HttpStatusCode.NotFound)
        {
            _sessionExpired = true;
            await Store.ClearAsync();
        }
    }

    private void GoToMenu() => Nav.NavigateTo("/");

    private async Task BackToMenuAsync()
    {
        await Store.ClearAsync();
        Nav.NavigateTo("/");
    }

    /// <summary>終了/ゲームオーバーから、同じプレイヤー名で新しい冒険を始める（/play に留まる）。</summary>
    private async Task ReplayAsync()
    {
        if (_busy)
        {
            return;
        }

        _busy = true;
        _error = null;
        _saveMessage = null;
        try
        {
            var name = Store.Current?.Player.Name;
            var state = await Api.CreateSessionAsync(string.IsNullOrWhiteSpace(name) ? null : name);
            await Store.ApplyAsync(state); // 別セッション ID なので累積ログはリセットされる。
        }
        catch (GameApiException ex)
        {
            await HandleApiErrorAsync(ex);
        }
        catch (Exception ex)
        {
            _error = $"通信に失敗しました: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }
}
